# 复制为 .env.local 并填入真实密钥（此文件可安全提交，不含密钥）
# Kimi / Moonshot OpenAI 兼容 API
#   国内控制台密钥 → https://api.moonshot.cn/v1（platform.moonshot.cn / Kimi 开放平台）
#   国际控制台密钥 → https://api.moonshot.ai/v1（platform.moonshot.ai）
EXTERNAL_MODEL_PROVIDER=moonshot-kimi
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.5
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
