# 复制为 .env.local 并填入真实密钥（此文件可安全提交，不含密钥）
# Kimi / Moonshot OpenAI 兼容 API
#   国内控制台密钥 → https://api.moonshot.cn/v1（platform.moonshot.cn / Kimi 开放平台）
#   国际控制台密钥 → https://api.moonshot.ai/v1（platform.moonshot.ai）
EXTERNAL_MODEL_PROVIDER=moonshot-kimi
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.5
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 如改用 OpenAI，可启用显式 prefix cache key 复用固定 system/tools 前缀的 KV cache
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_PREFIX_CACHE_ENABLED=1
# OPENAI_PROMPT_CACHE_NAMESPACE=private-ai-agent-system-prompt-v1
# OPENAI_PROMPT_CACHE_RETENTION=24h
# MOONSHOT_PREFIX_CACHE_ENABLED=1
# MOONSHOT_PROMPT_CACHE_NAMESPACE=private-ai-agent-system-prompt-v1

# ---------- 微信 Claw（OpenClaw Gateway，复制到 .env.local）----------
# WECHAT_CLAW_ENABLED=1
# OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_AUTH=none
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_WEIXIN_CHANNEL=openclaw-weixin
# 消息桥（与 App 同一套 AgentCore / 记忆 / 工具）：
# WECHAT_CLAW_BRIDGE_ENABLED=1
# WECHAT_CLAW_BRIDGE_ACTOR_ID=session-mvp-001
