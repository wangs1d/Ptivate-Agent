# 外部对话模型：
#   auto — 优先 Kimi（MOONSHOT_API_KEY），否则 OpenAI（OPENAI_API_KEY）
#   none — 关闭云端模型
#   moonshot-kimi | openai — 固定单一提供方
#   failover — 按 EXTERNAL_MODEL_FAILOVER_CHAIN 顺序故障切换（需至少一方密钥）
# EXTERNAL_MODEL_PROVIDER=auto

# failover 时的顺序（逗号分隔，id：moonshot-kimi、openai）
# EXTERNAL_MODEL_FAILOVER_CHAIN=moonshot-kimi,openai

# Moonshot Kimi API（与 OpenAI SDK 兼容）
# 密钥请写入同目录 .env.local（已 gitignore），勿写在本文件或提交 Git。
# 在 https://platform.kimi.ai 创建密钥后填入 server/.env.local：
#   MOONSHOT_API_KEY=sk-...
#   MOONSHOT_MODEL=kimi-k2.5
#   EXTERNAL_MODEL_PROVIDER=moonshot-kimi
# MOONSHOT_API_KEY=

# 可选，默认 kimi-k2.5
# MOONSHOT_MODEL=kimi-k2.5

# 可选 Base URL（须与密钥所属控制台一致，否则会 401 Invalid Authentication）
# 国内密钥（默认示例）：https://api.moonshot.cn/v1
# 国际密钥：https://api.moonshot.ai/v1
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 可选：高德 Web 服务 Key，GPS 逆地理优先走高德（需在控制台开通「Web 服务」）
# AMAP_WEB_KEY=

# IP 定位已禁用；时钟/位置仅依赖前端 GPS + /geo/reverse 逆地理

# 球形具身自主漫游（默认开启；设 0 关闭服务端自发身体移动）
# ENABLE_EMBODIMENT_AUTONOMY=1

# ---------- 主 Agent 委派子 Agent（支持并行 + 后台委派） ----------
# 1=启用：主 Agent 通过 master_invoke_sub_agent 动态委派子 Agent
# 子 Agent 委派（默认：已配置外部模型 API Key 时自动开启；显式关闭 ENABLE_MASTER_AGENT_DELEGATION=0）
# ENABLE_MASTER_AGENT_DELEGATION=1
# 兼容旧名（仍有效，后续版本可能移除）：ENABLE_MULTI_AGENT_COORDINATION=1
# 主 Agent 在对话中调用 master_invoke_sub_agent（默认开启）；设 0 关闭委派工具
# MASTER_AGENT_DELEGATE_VIA_TOOLS=1
# 恢复旧版「先 JSON 分解再串行调用」：MASTER_AGENT_LEGACY_DECOMPOSE=1
# 子 Agent 单次委派超时（毫秒，默认 60 秒）
# SUBTASK_TIMEOUT_MS=60000
# tech 子 Agent 专用超时（深度 RPA / 代码，默认 120 秒）
# TECH_SUBTASK_TIMEOUT_MS=120000
# info 子 Agent 专用超时（多轮联网检索，默认 90 秒）
# INFO_SUBTASK_TIMEOUT_MS=90000
# 每轮最多委派子 Agent 次数（默认 6）
# MASTER_AGENT_MAX_SUB_AGENT_INVOCATIONS=6
# 同时运行的子 Agent 上限（默认 3；同一 tool 批次内可并行委派）
# MAX_PARALLEL_SUB_AGENTS=3
# 强制主 Agent 额外合成 LLM（默认子 Agent 全成功且较短时跳过）
# MASTER_AGENT_FORCE_SYNTHESIS=1
# 子 Agent 全成功且拼接结果不超过该字数时，跳过额外合成 LLM（默认 2800）
# MASTER_AGENT_DIRECT_REPLY_MAX_CHARS=2800
# 主 Agent 委派详细日志（默认 false）
# MASTER_AGENT_DELEGATION_VERBOSE=false
# 兼容旧名：MULTI_AGENT_VERBOSE=false

# OpenAI 官方 API（与 auto / openai / failover 配合）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- 硅基流动 TTS（中文语音合成，OpenAI 兼容接口，优先于 OpenAI TTS） ----------
# 在 https://cloud.siliconflow.cn 创建账号获取 API Key
# SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 可选：TTS 模型（默认 FunAudioLLM/CosyVoice2-0.5B，中文效果好）
# SILICONFLOW_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
# 可选：自定义 Base URL（默认 https://api.siliconflow.cn/v1）
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ---------- 联网搜索（国内源，已移除 Jina/DuckDuckGo/Google News/Exa） ----------
# 搜索：必应中国 RSS + 36氪/IT之家 RSS；读页：直连抓取
# 带发布时间的搜索结果超过该天数则剔除（默认 120）；查历史/百科类长句不受此限
# SEARCH_MAX_ITEM_AGE_DAYS=120

# 可选：上游命令路径（不填则使用系统 PATH）
# MCPORTER_BIN=mcporter
# GH_BIN=gh
# RDT_BIN=rdt
# YTDLP_BIN=yt-dlp

# 国内平台建议在 mcporter 中配置的 server alias：
# weibo / xiaohongshu(或 xhs) / wechat / douyin

# ---------- MCP 客户端（Model Context Protocol） ----------
# 通过 mcporter CLI 连接 MCP Server，动态发现并注册工具到主 Agent
# 配置方式一：环境变量（逗号分隔 server alias）
# MCP_SERVERS=weibo,xiaohongshu,wechat,douyin
# 配置方式二：JSON 配置文件（支持 description、enabled 等字段）
# MCP_SERVERS_CONFIG=data/mcp-servers.json
# mcporter 二进制路径（不填则使用系统 PATH 中的 mcporter）
# MCPORTER_BIN=mcporter

# ---------- Agent World ----------
# 对外可访问的 Agent World 网页根地址（生成 playUrl / watchUrl 时使用）
# 主服务内嵌世界 API：http://127.0.0.1:3000  独立站 Web UI：http://127.0.0.1:3333
# AGENT_WORLD_PUBLIC_URL=http://127.0.0.1:3000
# AGENT_WORLD_STANDALONE_URL=http://127.0.0.1:3333

# 本地一键启动：npm run dev:all（根目录，同时开 server + agent-world:3333）

# 开发/联调：允许 Agent 快速注册（无 SHA-256 题）。生产环境勿设为 1。
# AGENT_WORLD_PLACEHOLDER_REGISTER=1

# 允许通过 HTTP 修改世界（购买、斗地主开桌等）；默认关闭，仅工具可写。
# ALLOW_WORLD_HTTP_MUTATIONS=1

# Agent 中继是否强制同配对码互通（默认关闭）。
# AGENT_RELAY_REQUIRE_PAIR=0

# 可选：世界状态落盘路径（默认进程 cwd 下 data/world-state.json）
# WORLD_STATE_FILE=

# 服务端口（默认 3000）
# PORT=3000

# Agent World 独立站监听端口（npm run dev 内嵌启动时固定 3333；勿与 PORT 共用）
# AGENT_WORLD_STANDALONE_PORT=3333

# ---------- 五子棋 Agent 应手（默认由 LLM Agent 落子，需 MOONSHOT_API_KEY 或 OPENAI_API_KEY）----------
# 仅调试：强制本地启发式、跳过 LLM
# GOMOKU_HEURISTIC_MOVES=1
# 落子 LLM 超时（毫秒，默认 5000）；多次失败后才启发式回退
# GOMOKU_TURN_TIMEOUT_MS=5000
# 旁白 LLM 超时（毫秒，默认 2500）；旁白异步推送，不阻塞下一手
# GOMOKU_BANTER_TIMEOUT_MS=2500
# 五子棋专用快模型（如 moonshot-v1-8k）；不设则用 MOONSHOT_MODEL / OPENAI_MODEL
# GOMOKU_FAST_MODEL=moonshot-v1-8k

# ---------- Mem0 记忆图（agentic-memory，实体链接 + 跨主题联想） ----------
# AGENT_AGENTIC_MEMORY_ENABLED=true
# AGENT_AGENTIC_MEMORY_DIR=data/agentic_memory
# AGENT_AGENTIC_MEMORY_COLLECTION=agentic_memories
# AGENT_AGENTIC_MEMORY_TOP_K=8
# AGENT_AGENTIC_MEMORY_LLM_MODEL=gpt-4o-mini
# AGENT_AGENTIC_MEMORY_INSTRUCTIONS=
# AGENT_QDRANT_URL=
# AGENT_QDRANT_API_KEY=
# AGENT_EMBEDDING_MODEL=text-embedding-3-small
# AGENT_KV_SUMMARY_APPEND_MODE=minimal

# ---------- TokenJuice（工具结果压缩） ----------
# AGENT_TOKENJUICE_ENABLED=true
# AGENT_TOKENJUICE_MAX_TOOL_CHARS=12000

# ---------- Tool Search（核心工具库 + 延迟目录，减少 tools schema 占用） ----------
# AGENT_TOOL_SEARCH_ENABLED=auto
# AGENT_TOOL_SEARCH_BRIDGE_MODE=merged
# AGENT_TOOL_SEARCH_DISCOVER_AUTO_SCHEMA=true
# AGENT_TOOL_SEARCH_THRESHOLD_PCT=10
# AGENT_TOOL_SEARCH_DEFAULT_LIMIT=5
# AGENT_TOOL_SEARCH_MAX_LIMIT=20
# AGENT_TOOL_SEARCH_CONTEXT_TOKENS=32000

# UAP 慢变量注入 system（人格/价值观/能力/履历）；未设置时默认注入 persona/values/abilities/memory_summary/important_dates
# AGENT_PROMPT_MEMORY_KEYS=off
# AGENT_PROMPT_MEMORY_KEYS=persona,values,abilities,memory_summary,important_dates
# AGENT_PROMPT_MEMORY_SUMMARY_MAX_CHARS=6000
# AGENT_PROMPT_MEMORY_SUMMARY_MAX_LINES=25
# AGENT_SUBAGENT_MEMORY_SUMMARY_MAX_LINES=12
# AGENT_SUBAGENT_MEMORY_SUMMARY_MAX_CHARS=3000

# Agent 能力摘要注入 system（默认关闭以加快首 token；需要时再设为 1）
# 注入 Agent 专属能力与世界说明到 system prompt（默认开启；设 0/off 关闭以缩短 prompt）
# AGENT_PROMPT_WORLD_CAPS=1

# 长期记忆检索超时（毫秒，超时则跳过记忆块继续回复，默认 400）
# AGENT_NARRATIVE_RECALL_TIMEOUT_MS=400

# ---------- 用户画像与情感语气适配（USER_PROFILE.md） ----------
# AGENT_USER_PERSONALIZATION_ENABLED=1
# AGENT_USER_PROFILE_DIR=data/user_profiles
# AGENT_USER_PROFILE_PROMPT_MAX_CHARS=3500
# AGENT_USER_PROFILE_LLM_EVERY_N=8

# ---------- 短期对话线程落盘（重启后恢复最近 N 条消息，默认开启） ----------
# AGENT_CHAT_THREAD_PERSIST=1
# AGENT_CHAT_THREAD_PERSIST_MAX_MESSAGES=40
# AGENT_CHAT_THREAD_PERSIST_FILE=data/chat-threads.json

# ---------- 短期记忆增强（WAL + 当日 digest + 高信号 fast-path，默认 enhanced） ----------
# AGENT_SHORT_TERM_MEMORY=enhanced
# AGENT_TURN_WAL_ENABLED=1
# AGENT_TURN_WAL_DIR=data/turn-wal
# AGENT_DAILY_DIGEST_ENABLED=1
# AGENT_DAILY_DIGEST_FILE=data/daily-digests.json

# ---------- Memory Tree（权重迭代 · 事件淡化 · 用户了解度） ----------
# AGENT_MEMORY_TREE_ENABLED=true
# AGENT_MEMORY_FORGET_THRESHOLD=0.12
# AGENT_MEMORY_COGNITION_MIN_WEIGHT=0.35
# AGENT_MEMORY_HIGH_SIGNAL_BOOST=0.25
# AGENT_MEMORY_COGNITION_LLM=1
# AGENT_MEMORY_COGNITION_SYNC_PROFILE=1
# AGENT_DAILY_DIGEST_MAX_CHARS=4000
# AGENT_DAILY_DIGEST_PROMPT_MAX_CHARS=2500
# AGENT_DAILY_DIGEST_TIMEZONE=Asia/Shanghai
# AGENT_DEFER_TURN_ARCHIVE=1

# ---------- 计划-执行循环（Plan-Execute Loop） ----------
# AGENT_PLAN_EXECUTE_LOOP=1 — 启用复杂任务的"计划→执行"流程（已移除自检环节，减少 50%+ LLM 调用）
# AGENT_PE_VERBOSE_STREAM=1 — 将阶段标题写入用户可见流

# 真实资金钱包默认币种与初始余额（与 Agent World 点数分离）
# REAL_FUNDS_DEFAULT_CURRENCY=CNY
# REAL_FUNDS_INITIAL_BALANCE=1000

# ---------- 桌面桥接（Agent ↔ 本机 PC 截屏/键鼠） ----------
# DESKTOP_BRIDGE_ENABLED=1
# Windows Flutter 桌面端会在同 userId 下自动注册桥接（无需 Python 脚本）；与 Python 桥勿同时绑定同一 userId。
# 随 server 启动自动 spawn Python 桥接（Flutter 单机使用时建议 DESKTOP_BRIDGE_AUTO_START=0）
# DESKTOP_BRIDGE_AUTO_START=1
# 桥接 userId，须与客户端 USER_ID 或 sessionId 一致
# DESKTOP_BRIDGE_USER_ID=session-mvp-001
# DESKTOP_BRIDGE_WS_URL=ws://127.0.0.1:3000/ws
# Python 与 desktop-visual 目录（可选）
# DESKTOP_VISUAL_PYTHON=python
# DESKTOP_VISUAL_ROOT=../desktop-visual
# 服务端本机截屏/键鼠（不经过 PC 桥接时）
# DESKTOP_VISUAL_ENABLED=1

# 日程任务持久化文件（默认 data/schedule-tasks.json）
# SCHEDULE_TASKS_FILE=

# ---------- 微信 Claw（OpenClaw openclaw-weixin 渠道） ----------
# 须在本机运行 OpenClaw Gateway，并安装 @tencent-weixin/openclaw-weixin 插件
# WECHAT_CLAW_ENABLED=1
# OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789
# 本地开发（npm run dev:all 会自动起 Gateway）：OPENCLAW_GATEWAY_AUTH=none，token 可留空
# OPENCLAW_GATEWAY_AUTH=none
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token
# 或使用密码：OPENCLAW_GATEWAY_PASSWORD=
# 首次：npm run setup:openclaw
# OPENCLAW_WEIXIN_CHANNEL=openclaw-weixin
# 绑定记录落盘（默认 data/wechat-claw-bindings.json）
# WECHAT_CLAW_BINDING_FILE=
# 可选：固定 OpenClaw accountId；不设则使用 Gateway 默认账号
# WECHAT_CLAW_ACCOUNT_ID=
# WECHAT_CLAW_ACCOUNT_ID_PREFIX=private-agent-

# ---------- 微信消息桥（OpenClaw 只收发，推理走主服务 AgentCore）----------
# 启用后请执行：npm run setup:openclaw-wechat-bridge
# WECHAT_CLAW_BRIDGE_ENABLED=1
# 与 Flutter USER_ID / DESKTOP_BRIDGE_USER_ID 对齐
# WECHAT_CLAW_BRIDGE_ACTOR_ID=session-mvp-001
# 非本机访问时必填（OpenClaw 插件请求鉴权）
# WECHAT_CLAW_BRIDGE_TOKEN=
# 与 App 对齐：sandbox（默认）或 full
# WECHAT_CLAW_BRIDGE_AGENT_ACCESS_MODE=sandbox
