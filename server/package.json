{
  "name": "private-ai-agent-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev:server": "npm run build --prefix ../agent-world",
    "dev:server:watch": "node ../scripts/dev-server-watch.mjs",
    "dev:server": "npm run predev:server && npm run dev:server:watch",
    "dev:stack": "npm run dev:all --prefix ..",
    "dev:all": "npm run dev:all --prefix ..",
    "dev": "npm run dev:all --prefix ..",
    "dev:ports:free": "npm run dev:ports:free --prefix ..",
    "build": "npm run build --prefix ../agent-world && tsc -p tsconfig.json",
    "start": "node scripts/start-with-gateway.mjs",
    "start:server": "node dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "test:master-agent": "tsx test/master-agent.test.ts",
    "bench:ttft": "tsx scripts/bench-ttft.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/websocket": "^11.0.2",
    "@private-ai-agent/agent-world": "0.1.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "cloudflare": "^4.5.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "mem0ai": "^3.0.3",
    "openai": "^6.34.0",
    "playwright": "^1.60.0",
    "qrcode": "^1.5.4",
    "redis": "^4.7.1",
    "tokenjuice": "^0.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.6",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
