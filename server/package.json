{
  "name": "private-ai-agent-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build --prefix ../agent-world",
    "dev": "tsx watch src/index.ts",
    "build": "npm run build --prefix ../agent-world && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "test:master-agent": "tsx test/master-agent.test.ts",
    "bench:ttft": "tsx scripts/bench-ttft.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/websocket": "^11.0.2",
    "@private-ai-agent/agent-world": "0.1.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "openai": "^6.34.0",
    "redis": "^4.7.1",
    "tokenjuice": "^0.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
